"""
팬 제어 노드 (노트북에서 실행)
- /wind_start 받으면 3초 대기 후 팬 ON, 10초 유지 후 OFF
- MPC 코드의 get_wind(WIND_MAX)와 짝을 이룸. 팬 파워 바꾸면 MPC도 같이 바꿔야 함.
"""

import rclpy
from rclpy.node import Node
from std_msgs.msg import Empty

import time
import threading
import windcontrol

# ================= 설정 =================
FAN_POWER      = 90.0    # 팬 파워 (%)  [100% = 16 m/s 가정]
DELAY_BEFORE   = 3.0     # 신호 받고 팬 켜기까지 대기 (초)
WIND_DURATION  = 20.0    # 바람 유지 시간 (초)
# =======================================


class FanNode(Node):
    def __init__(self):
        super().__init__('fan_node')

        self.get_logger().info('WindShaper 연결 중...')
        self.windshaper = windcontrol.WindShaper(verbose=False)
        self.windshaper.startServerLink()
        self.windshaper.requestToken()
        time.sleep(1)
        self.windshaper.startPSUs()
        time.sleep(2)
        self.get_logger().info(f'팬 준비 완료 (목표 {FAN_POWER}%). /wind_start 신호 대기 중...')

        self.wind_running = False

        self.sub = self.create_subscription(
            Empty, '/wind_start', self.wind_start_callback, 10)

    def wind_start_callback(self, msg):
        if self.wind_running:
            self.get_logger().warn('이미 바람 시퀀스 진행 중 - 신호 무시')
            return
        self.get_logger().info('/wind_start 수신! 바람 시퀀스 시작')
        self.wind_running = True
        t = threading.Thread(target=self.run_wind_sequence, daemon=True)
        t.start()

    def run_wind_sequence(self):
        try:
            self.get_logger().info(f'{DELAY_BEFORE}초 후 팬 ON 예정...')
            time.sleep(DELAY_BEFORE)
            self.get_logger().info(f'팬 ON ({FAN_POWER}%)')
            self.windshaper.setFanPower(FAN_POWER)
            time.sleep(WIND_DURATION)
            self.windshaper.setFanPower(0)
            self.get_logger().info('팬 OFF (바람 종료). 드론 복귀/착륙 가능.')
        except Exception as e:
            self.get_logger().error(f'에러 발생: {e} -> 팬 강제 OFF')
            try:
                self.windshaper.setFanPower(0)
            except:
                pass
        finally:
            self.wind_running = False

    def shutdown_fans(self):
        self.get_logger().info('노드 종료 - 팬 정리 중...')
        try:
            self.windshaper.setFanPower(0)
            self.windshaper.turnOffModules()
            self.windshaper.releaseToken()
            self.windshaper.stopServerLink()
            self.get_logger().info('팬 정리 완료.')
        except Exception as e:
            self.get_logger().error(f'팬 정리 중 에러: {e}')


def main():
    rclpy.init()
    node = FanNode()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        print("\n[fan_node] 중단됨")
    finally:
        node.shutdown_fans()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()




































