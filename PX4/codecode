from rclpy.qos import QoSProfile, ReliabilityPolicy, HistoryPolicy
                                        # 통신 품질(얼마나 꼼꼼히/빠르게 주고받을지) 설정 도구
import numpy as np                      # 숫자/배열 계산 도구. 'np'로 줄여 부름
import casadi as ca                     # 수식을 기호로 다루는 도구. 운동방정식을 적는 데 사용
from acados_template import AcadosOcp, AcadosOcpSolver, AcadosModel
                                        # ACADOS로 NMPC 문제를 세팅하고 푸는 도구 3종

